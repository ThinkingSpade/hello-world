# Copy to .env and fill in. Only GROQ_API_KEY is required for prod mode;
# leave ATLAS_LLM=extractive to run without any key.

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Component selection (demo defaults shown; docker-compose overrides these)
ATLAS_LLM=extractive        # extractive | groq
ATLAS_STORE=memory          # memory | pgvector
ATLAS_CACHE=memory          # memory | redis
ATLAS_EMBEDDER=hashing      # hashing | fastembed

# Local (non-docker) service addresses. docker-compose ignores these two and
# uses its own in-network hostnames.
DATABASE_URL=postgresql://atlas:atlas@localhost:5432/atlas
REDIS_URL=redis://localhost:6379/0

# Host port for the UI/API (compose maps this onto the container's 8300).
ATLAS_PORT=8300

# Optional: if set, POST /api/reindex requires "Authorization: Bearer <token>".
ATLAS_ADMIN_TOKEN=
